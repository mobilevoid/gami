# GAMI Configuration
# Copy to .env and configure your values

# =============================================================================
# Database (PostgreSQL 16 with pgvector)
# =============================================================================
GAMI_DB_USER=gami
GAMI_DB_PASSWORD=your_secure_password_here
GAMI_DB_NAME=gami
GAMI_DB_PORT=5433

# Full connection URLs (computed from above or set directly)
DATABASE_URL=postgresql+asyncpg://gami:your_secure_password_here@localhost:5433/gami
DATABASE_URL_SYNC=postgresql://gami:your_secure_password_here@localhost:5433/gami

# =============================================================================
# Redis
# =============================================================================
GAMI_REDIS_PORT=6380
REDIS_URL=redis://localhost:6380/0

# =============================================================================
# LLM Backend Configuration
# =============================================================================
# Choose one: ollama, vllm, openai, anthropic
GAMI_LLM_BACKEND=ollama

# Ollama (local, free, CPU or GPU)
OLLAMA_URL=http://localhost:11434
GAMI_LLM_MODEL=llama3.2

# vLLM (local GPU server)
VLLM_URL=http://localhost:8000/v1
# GAMI_LLM_MODEL=your-model-name

# OpenAI API (requires API key)
OPENAI_API_KEY=
# GAMI_LLM_MODEL=gpt-4o-mini

# Anthropic API (requires API key)
ANTHROPIC_API_KEY=
# GAMI_LLM_MODEL=claude-sonnet-4-20250514

# =============================================================================
# Embedding
# =============================================================================
EMBEDDING_MODEL=nomic-embed-text

# =============================================================================
# API Server
# =============================================================================
GAMI_API_PORT=9090
GAMI_API_KEY=  # Optional: set to require API key authentication
GAMI_LOG_LEVEL=INFO

# =============================================================================
# Storage Paths
# =============================================================================
# GAMI_OBJECT_STORE=/opt/gami/storage/objects
# GAMI_COLD_STORE=/opt/gami/storage/cold

# =============================================================================
# Dream Cycle
# =============================================================================
GAMI_DREAM_DURATION=3600          # Duration per cycle in seconds
GAMI_DREAM_INTERVAL=21600         # Interval between cycles (6 hours)
GAMI_DREAM_IDLE_CHECK=true        # Check for idle before running
GAMI_DREAM_MAX_DURATION=28800     # Max total runtime (8 hours)

# =============================================================================
# Reranker (optional, improves retrieval precision by 25-40%)
# =============================================================================
GAMI_RERANKER_ENABLED=true
GAMI_RERANKER_TOP_K=50
GAMI_RERANKER_FINAL_K=10
GAMI_RERANKER_BLEND_RATIO=0.7
# GAMI_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# =============================================================================
# Backup (optional)
# =============================================================================
# GAMI_BACKUP_DIR=/var/backups/gami
# GAMI_REMOTE_BACKUP_DIR=/mnt/nas/backups/gami
# RETENTION_DAILY=7
# RETENTION_WEEKLY=4
