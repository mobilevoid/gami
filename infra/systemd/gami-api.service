[Unit]
Description=GAMI API Server
After=network.target postgresql.service redis-gami.service

[Service]
Type=simple
User=ai
Group=ai
WorkingDirectory=/opt/gami
Environment=PYTHONPATH=/opt/gami
ExecStart=/usr/local/anaconda3/bin/python -m uvicorn api.main:app --host 0.0.0.0 --port 9000 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
